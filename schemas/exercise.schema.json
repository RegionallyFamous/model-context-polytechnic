{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://model-context-polytechnic.local/schemas/exercise.schema.json",
  "title": "Model Context Polytechnic Exercise",
  "type": "object",
  "required": [
    "position",
    "slug",
    "lesson_slug",
    "title",
    "prompt",
    "passing_score",
    "rubric"
  ],
  "properties": {
    "position": {
      "type": "integer"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "lesson_slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "hints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "passing_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "expected_output_schema": {
      "type": "object"
    },
    "rubric": {
      "type": "object",
      "required": ["criteria"],
      "properties": {
        "criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "points"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "points": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "required_terms": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "any_terms": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
