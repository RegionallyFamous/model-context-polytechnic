{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://model-context-polytechnic.local/schemas/course-pack.schema.json",
  "title": "Model Context Polytechnic Course Pack",
  "type": "object",
  "required": [
    "schema_version",
    "slug",
    "name",
    "description",
    "instructions",
    "modules"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "pack_version": {
      "type": "string"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "voice": {
      "type": "object"
    },
    "instructions": {
      "type": "string",
      "minLength": 1
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slug", "title", "lessons", "exercises"],
        "properties": {
          "position": {
            "type": "integer"
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string"
          },
          "lessons": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["slug", "title", "file"],
              "properties": {
                "position": {
                  "type": "integer"
                },
                "slug": {
                  "type": "string",
                  "pattern": "^[a-z0-9-]+$"
                },
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "objectives": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "file": {
                  "type": "string",
                  "pattern": "^lessons/.+\\.md$"
                }
              },
              "additionalProperties": false
            }
          },
          "exercises": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["file"],
              "properties": {
                "file": {
                  "type": "string",
                  "pattern": "^exercises/.+\\.json$"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "title", "file"],
        "properties": {
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "pattern": "^references/.+\\.md$"
          },
          "mime_type": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
