{
  "name": "model-context-polytechnic/model-context-polytechnic",
  "type": "wordpress-plugin",
  "description": "A public MCP learning and diagnostics server for WordPress.",
  "license": "proprietary",
  "require": {
    "php": ">=8.1",
    "wordpress/mcp-adapter": "^0.5",
    "automattic/jetpack-autoloader": "^5.0"
  },
  "config": {
    "allow-plugins": {
      "automattic/jetpack-autoloader": true
    }
  },
  "scripts": {
    "lint": "php bin/lint.php",
    "course-packs:validate": "php bin/validate-course-packs.php",
    "course-flow:simulate": "php bin/simulate-course-flow.php",
    "course-lab": "php bin/course-lab.php --passes=6",
    "cohort-lab": "php bin/course-lab.php --passes=6 --students=10",
    "extended-cohort-lab": "php bin/course-lab.php --passes=6 --students=20",
    "stress-lab": "php bin/stress-lab.php",
    "http-course-smoke": "php bin/http-course-smoke.php",
    "http-course-completion-smoke": "php bin/http-course-completion-smoke.php",
    "foundation:check": "php bin/foundation-check.php",
    "version:bump": "php bin/bump-version.php",
    "test": [
      "@course-packs:validate",
      "@course-flow:simulate",
      "@course-lab",
      "@stress-lab"
    ],
    "release:build": "php bin/build-release.php",
    "release:check": [
      "@lint",
      "@test"
    ]
  }
}
